{
  "name": "agig-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Avant Garde International Group — marketing site (single-file static build) + preview/build tooling.",
  "scripts": {
    "render": "node scripts/render.mjs",
    "serve": "python3 -m http.server 8080",
    "fonts": "node scripts/fetch-fonts.mjs",
    "format": "prettier --write \"*.html\"",
    "format:check": "prettier --check \"*.html\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "puppeteer": "^23.0.0"
  }
}
